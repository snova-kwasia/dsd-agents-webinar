SAMBANOVA_API_KEY=your_sambanova_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Langfuse observability (optional)
# Each Langfuse API key pair is tied to a specific project.
# To create keys: open Langfuse UI → create a project (e.g. "dsd_deep_agents_session_1") → Settings → API Keys → Create
# For self-hosted (default): LANGFUSE_BASE_URL=http://localhost:3000
# For cloud: LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_BASE_URL=http://localhost:3000

# LangSmith observability (optional)
# Sign up at https://smith.langchain.com/
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
